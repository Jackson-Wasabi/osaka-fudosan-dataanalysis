# raw データは公開しない（手順書 v9 GitHub 公開ルール）
# ディレクトリ構造の再現用に .gitkeep のみ追跡する
data/raw/*
!data/raw/.gitkeep
data/gis/raw/*
!data/gis/raw/.gitkeep

# 認証情報・秘密情報
.env
*.env
profiles.yml
**/profiles.yml
*service-account*.json
*credentials*.json
*.pem
*.key

# dbt 生成物
dbt/target/
dbt/dbt_packages/
dbt/logs/
logs/

# Python
__pycache__/
*.pyc
.venv/

# OS / IDE
.DS_Store
Thumbs.db
.vscode/

# Tableau 抽出・作業ファイル（最終成果はTableau Publicのリンク。再現は分析パイプライン＋READMEで担保）
*.hyper
*.twbx
*.twb
*.twbr
~$*

# 公開しない内部資料（作業ルール・進行管理メモ。公開リポジトリには含めない）
CLAUDE.md
docs/portfolio_completion_manual.html
docs/portfolio_completion_manual.pdf
docs/_portfolio_process_notes.md
# デッキ/スクショ生成などの制作ツール（分析パイプラインではない）
scripts/make_storyboard.py
scripts/make_summary_revised.py
scripts/make_wireframe.py
scripts/shot.py
scripts/shot.ps1

# 面接準備・就活向け資料（会社名・就活戦略を含む。公開しない）
docs/interview_notes.md
docs/_interview_prep_GA.md
docs/project_brief.md

# READMEから生成する派生PDF（添付用・ローカル）
portfolio_overview.pdf

# ポートフォリオのデザイン版バックアップ（必要なら復元用・ローカル）
index_redesign_backup.html

# 目次改善版の比較用ドラフト（採用したらindex.htmlへ反映）
index_v2.html
index_v3.html
_gen_v4.py
index_v4.html
index_v5.html
_gen_v6.py
index_v6.html
